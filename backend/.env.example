PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/memory_db?schema=public"

# Access token: short-lived (5 minutes), verified by JwtAuthGuard on every request.
JWT_SECRET="super-secret-key-change-in-production"

# Refresh token: long-lived (30 days), verified by JwtRefreshGuard on /auth/refresh and /auth/logout only.
# MUST be a different secret from JWT_SECRET — prevents refresh tokens from being used as access tokens.
REFRESH_TOKEN_SECRET="another-super-secret-key-change-in-production"

REDIS_URL="redis://localhost:6379"

# Comma-separated list of allowed CORS origins.
# Use * only during local dev — always restrict in production.
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8080"

# Cloudflare R2 / S3 Configuration
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
